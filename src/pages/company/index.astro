---
import PageLayout from '../../layouts/PageLayout.astro';

const info = [
  { label: '社名',     value: 'ミント合同会社' },
  { label: '英語名',   value: 'MINT LLC' },
  { label: '事業内容', value: 'アンティークコイン・モダンコインの情報提供、コンサルティング事業' },
  { label: 'メール',   value: 'info@mint-coin.jp' },
];

const policies = [
  {
    title: '正確な情報提供',
    body: 'コインに関する情報は、造幣局公式資料、PCGS・NGC のデータベース、信頼性の高い一次資料に基づいて掲載します。不確かな情報は「確認中」として明示します。',
  },
  {
    title: '販売利益を目的としない情報発信',
    body: '当サイトは情報提供を主目的としています。販売ありきの価格評価や投資煽り的な表現を排除し、コレクターや関心を持つ方が自律的に判断できる情報を提供します。',
  },
  {
    title: '透明性の確保',
    body: '当社が将来的にコインの売買・仲介を行う際には、その旨を明示し、情報提供とビジネス活動を明確に区別します。',
  },
];
---

<PageLayout
  title="会社概要"
  description="MINT COINを運営するミント合同会社の会社概要と運営方針をご紹介します。"
>
  <!-- Page Hero -->
  <section class="bg-ivory py-12 border-b border-parchment">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-gray-400 mb-4">
        <a href="/" class="hover:text-navy-700 transition-colors">ホーム</a>
        <span class="mx-2">›</span>
        <span class="text-gray-600">会社概要</span>
      </nav>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-navy-900">会社概要</h1>
      <p class="mt-3 text-gray-600 max-w-2xl leading-loose">
        MINT COIN を運営するミント合同会社についてご紹介します。
      </p>
    </div>
  </section>

  <!-- Company Info -->
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="font-serif text-2xl font-semibold text-navy-900 mb-3">会社情報</h2>
        <div class="w-8 h-px bg-gold-500"></div>
      </div>
      <dl class="divide-y divide-parchment">
        {info.map(({ label, value }) => (
          <div class="flex py-4 gap-8">
            <dt class="text-sm text-gray-400 w-24 shrink-0">{label}</dt>
            <dd class="text-sm text-navy-800">
              {label === 'メール'
                ? <a href={`mailto:${value}`} class="hover:text-gold-600 transition-colors">{value}</a>
                : value
              }
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Policy -->
  <section class="bg-ivory py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="font-serif text-2xl font-semibold text-navy-900 mb-3">運営方針</h2>
        <div class="w-8 h-px bg-gold-500"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {policies.map(({ title, body }) => (
          <div class="bg-white p-7 border border-parchment rounded">
            <h3 class="font-serif text-base font-semibold text-navy-800 mb-3">{title}</h3>
            <p class="text-sm text-gray-600 leading-loose">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="bg-white py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="w-8 h-px bg-gold-500 mx-auto mb-10"></div>
      <blockquote class="font-serif text-xl text-navy-800 leading-snug font-medium">
        「販売ありきではなく、<br />正確でわかりやすい情報提供を重視します。」
      </blockquote>
      <p class="text-sm text-gray-500 mt-6">— ミント合同会社</p>
    </div>
  </section>
</PageLayout>
