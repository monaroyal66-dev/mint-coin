---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="ホーム"
  description="mint-coin — アンティークコインの専門サイト。eBayで仕入れた希少コインをご紹介します。"
>
  <div class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
      <section class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">mint-coin</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          アンティークコインの専門サイト
        </p>
      </section>
    </main>
    <Footer />
  </div>
</BaseLayout>
